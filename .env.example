APP_NAME=Cobweb
ENVIRONMENT=development
DEBUG=True

# Postgres (matches the docker-compose postgres service)
DATABASE_URL=postgresql+asyncpg://cobweb:cobweb@postgres:5432/cobweb

# Redis (matches the docker-compose redis service)
REDIS_URL=redis://redis:6379/0

# Auth (generate: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=20160

# Demo copy-trade competition
DEMO_STARTING_BALANCE_USD=1000.0
DEFAULT_POSITION_SIZE_USD=50.0
COPY_ENTRY_MCAP_OFFSET_USD=2500.0

# Helius — get your key at https://dev.helius.xyz
# NEVER commit a real key to git.
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_API_URL=https://api.helius.xyz/v0

# Auth — generate with: openssl rand -hex 32


# Cache TTL (seconds)
CACHE_TTL_TOKEN=300
CACHE_TTL_WALLET=600
CACHE_TTL_CABAL=1800
CACHE_TTL_PRICE=60

# Rate limiting / analysis depth
HELIUS_REQUESTS_PER_SECOND=10
RATE_LIMIT_ENABLED=True
RATE_LIMIT_HEAVY_PER_MINUTE=10
RATE_LIMIT_LIGHT_PER_MINUTE=60
MAX_WALLETS_PER_CABAL_SCAN=50
MAX_TX_PAGES_FOR_EARLY_BUYERS=30
MAX_EARLY_BUYERS=150

# Early buyers
EARLY_BUY_MARKET_CAP_USD=10000

# Prices
SOL_PRICE_FALLBACK_USD=150.0

# Real-time indexing (Helius webhook → Postgres)
# Set the same value in the Helius dashboard webhook "Authentication header"
HELIUS_WEBHOOK_SECRET=
# Webhook ID from the Helius dashboard — enables dynamic copy-trade wallet tracking
HELIUS_WEBHOOK_ID=
INDEX_MAX_EARLY_BUYS_PER_TOKEN=150
DB_AUTO_CREATE=True

# Background leaderboard profitability stats

# Telegram alerts (create a bot via @BotFather, paste the token)

# Monitoring (optional): paste a Sentry DSN to enable error tracking
SENTRY_DSN=

# CORS origin for production
FRONTEND_ORIGIN=https://cobweb.so
